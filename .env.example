IMAGE=linux-desktop:latest
NAME=linux-desktop
HOST_IP=127.0.0.1
PORT=6080
CPUS=4
MEMORY=4G
VNC_GEOMETRY=1440x900
VNC_DEPTH=24
VNC_PASSWORD=apple

# Opt-in host mounts: uncomment and point at a file with one
# "HOST_PATH:CONTAINER_PATH[:ro|rw]" mount per line (see .mounts.example).
# Unset by default: no host paths are mounted.
# HOST_MOUNTS_FILE=.mounts
