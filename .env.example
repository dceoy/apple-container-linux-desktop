IMAGE=linux-desktop:latest
NAME=linux-desktop
HOST_IP=127.0.0.1
PORT=6080
CPUS=4
MEMORY=4G
VNC_GEOMETRY=1440x900
VNC_DEPTH=24
VNC_PASSWORD=apple

# Optional host mounts. Unset by default, so no host paths are mounted.
# Set HOST_MOUNTS_FILE to a local file containing one mount per line:
# HOST_MOUNTS_FILE=.mounts
#
# Example mount file lines:
# /path/on/host:/path/in/container:rw
# /path/on/host:/path/in/container:ro
#
# Blank lines and comments are ignored. Mode defaults to rw when omitted.
