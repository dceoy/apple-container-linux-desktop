VARIANT=ai
HOST_IP=127.0.0.1
PORT=6080
CPUS=4
MEMORY=4G
VNC_GEOMETRY=1440x900
VNC_DEPTH=24
VNC_PASSWORD=apple

# CONTAINERFILE, IMAGE, REMOTE_IMAGE, and NAME are derived from VARIANT by default:
# CONTAINERFILE=Containerfile.ai
# IMAGE=acld:ai
# REMOTE_IMAGE=ghcr.io/dceoy/acld/ai:latest
# NAME=acld-ai

# Optional host mounts. Unset by default, so no host paths are mounted.
# Set HOST_MOUNTS_FILE to a local file containing one mount per line:
# HOST_MOUNTS_FILE=.mounts
#
# Example mount file lines for the default agent user:
# /Users/you/Desktop:/home/agent/Desktop:rw
# /Users/you/Downloads:/home/agent/Downloads:ro
#
# Blank lines and comments are ignored. Mode defaults to rw when omitted.
