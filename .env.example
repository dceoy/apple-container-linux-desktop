VARIANT=ai
HOST_IP=127.0.0.1
PORT=6080
CPUS=4
MEMORY=4G
VNC_GEOMETRY=1440x900
VNC_DEPTH=24
# VNC_PASSWORD is generated randomly at startup when left empty.
VNC_PASSWORD=

# CONTAINERFILE, IMAGE, REMOTE_IMAGE, and NAME are derived from VARIANT by default:
# CONTAINERFILE=Containerfile.ai
# IMAGE=acld:ai
# REMOTE_IMAGE=ghcr.io/dceoy/acld-ai:latest
# NAME=acld-ai

# WORKSPACE_DIR and HOME_VOLUME are optional overrides; each defaults to a
# value acld.sh computes on its own (the current directory, and
# acld-<VARIANT>-home) when left unset here.
# WORKSPACE_DIR=/Users/you/projects/demo
# HOME_VOLUME=acld-ai-home
